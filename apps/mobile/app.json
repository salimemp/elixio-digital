{
  "expo": {
    "name": "Elixio Digital",
    "slug": "elixio-digital",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "elixio",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.elixiodigital",
      "icon": "./assets/icon.png",
      "splash": {
        "image": "./assets/splash-icon.png",
        "backgroundColor": "#111111"
      }
    },
    "android": {
      "package": "com.elixiodigital",
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111111"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "extra": {
      "apiUrl": "",
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
