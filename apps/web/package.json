{
  "name": "@elixio/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && next-sitemap --config ../../next-sitemap.config.cjs",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "pages:build": "pnpm exec next-on-pages",
    "pages:deploy": "pnpm exec wrangler pages deploy .vercel/output/static",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@elixio/shared": "workspace:*",
    "@simplewebauthn/browser": "^13.3.0",
    "gray-matter": "^4.0.3",
    "next": "^14.2.15",
    "next-sitemap": "^4.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sanitize-html": "^2.13.1"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.5",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sanitize-html": "^2.13.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9",
    "wrangler": "^3.80.0"
  }
}
