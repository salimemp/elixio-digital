{
  "name": "@elixio/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "prebuild": "node ../../node_modules/prisma/build/index.js generate",
    "build": "node ../../node_modules/typescript/bin/tsc",
    "start": "node dist/apps/api/src/server.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@elixio/shared": "workspace:*",
    "@fastify/cors": "^9",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5",
    "@napi-rs/canvas": "^1.0.1",
    "@prisma/client": "^5.16",
    "@simplewebauthn/server": "^13.3.2",
    "archiver": "^8.0.0",
    "arctic": "^3.7.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4",
    "fastify": "^4.28",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "prisma": "^5.16",
    "qrcode": "^1.5.4",
    "resend": "^6.14.0",
    "sharp": "^0.35.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.0"
  }
}
