generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  buyer
  creator
  admin
}

enum AssetStatus {
  draft
  published
  archived
  rejected
}

enum MediaKind {
  image
  video
}

enum LicenseCode {
  personal
  commercial
  extended
}

enum OrderStatus {
  pending
  paid
  refunded
  failed
}

enum PayoutStatus {
  scheduled
  processing
  paid
  failed
}

enum OAuthProvider {
  google
  github
}

enum MfaFactorType {
  totp
  webauthn
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String?  // null after soft-delete (password-auth no longer valid)
  role         UserRole
  displayName  String
  avatarUrl    String?
  bio          String?
  isBuyer      Boolean  @default(true)
  isCreator    Boolean  @default(false)
  isVerified   Boolean  @default(false)
  emailVerifiedAt   DateTime?
  mfaEnabled        Boolean   @default(false)
  mfaEnrolledAt     DateTime?
  lastMfaVerifiedAt DateTime?
  lockedUntil       DateTime?
  deletedAt    DateTime?  // soft-delete tombstone (GDPR Art. 17 + CCPA)
  scheduledHardDeleteAt DateTime?  // +30 days from deletedAt
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  storefront    Storefront?
  assets        Asset[]
  orders        Order[]
  orderItems    OrderItem[]
  refreshTokens RefreshToken[]
  reviews       Review[]
  downloadGrants DownloadGrant[]
  payouts       Payout[]
  discountCodes DiscountCode[]
  collections   Collection[]

  // Creator analytics + AI
  assetViews        AssetView[]
  assetDownloads    AssetDownload[]
  aiGenerations     AIGeneration[]
  analyticsSnapshots AnalyticsSnapshot[]
  bulkOperations    BulkOperation[]

  emailVerifications EmailVerification[]
  passwordResets     PasswordResetToken[]
  magicLinks         MagicLinkToken[]
  oauthAccounts      OAuthAccount[]
  passkeys           Passkey[]
  mfaFactors         MfaFactor[]
  mfaBackupCodes     MfaBackupCode[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model EmailVerification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("email_verifications")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_resets")
}

model MagicLinkToken {
  id        String    @id @default(uuid()) @db.Uuid
  email     String
  userId    String?   @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, createdAt])
  @@index([tokenHash])
  @@map("magic_links")
}

model OAuthAccount {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @db.Uuid
  provider          OAuthProvider
  providerAccountId String
  email             String?
  accessTokenEnc    String?
  refreshTokenEnc   String?
  idTokenEnc        String?
  expiresAt         DateTime?
  scope             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

model Passkey {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  credentialId String    @unique
  publicKey    String
  counter      BigInt    @default(0)
  transports   String[]
  aaguid       String?
  name         String
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("passkeys")
}

model WebAuthnChallenge {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String?   @db.Uuid
  challenge String    @unique
  type      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([challenge])
  @@map("webauthn_challenges")
}

model MfaFactor {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @db.Uuid
  type         MfaFactorType
  totpSecretEnc String?
  passkeyId    String?       @db.Uuid
  enrolledAt   DateTime      @default(now())
  lastUsedAt   DateTime?
  revokedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("mfa_factors")
}

model MfaBackupCode {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("mfa_backup_codes")
}

model LoginAttempt {
  id          String   @id @default(uuid()) @db.Uuid
  email       String
  userId      String?  @db.Uuid
  ipAddress   String?
  userAgent   String?
  country     String?  // ISO country name from GeoIP
  countryCode String?  // ISO 3166-1 alpha-2
  city        String?
  success     Boolean
  method      String
  reason      String?
  isNewLocation Boolean @default(false)  // true if login from a new country/IP
  createdAt   DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@index([userId, createdAt])
  @@map("login_attempts")
}

model Storefront {
  id                     String  @id @default(uuid()) @db.Uuid
  userId                 String  @unique @db.Uuid
  slug                   String  @unique
  bannerUrl              String?
  accentColor            String?
  socialLinks            Json    @default("{}")
  stripeConnectAccountId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@map("storefronts")
}

model Asset {
  id           String      @id @default(uuid()) @db.Uuid
  creatorId    String      @db.Uuid
  title        String
  slug         String      @unique
  description  String
  categoryId   String      @db.Uuid
  priceCents   Int
  currency     String      @default("USD")
  licenseId    String      @db.Uuid
  status       AssetStatus @default(draft)
  searchVector String?
  avgRating    Float?
  reviewCount  Int         @default(0)
  salesCount   Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  creator     User              @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  category    Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  license     License           @relation(fields: [licenseId], references: [id], onDelete: Restrict)
  files       AssetFile[]
  media       AssetMedia[]
  reviews     Review[]
  orderItems  OrderItem[]
  tags        AssetTag[]
  collections CollectionAsset[]

  // Creator analytics
  views               AssetView[]
  downloads           AssetDownload[]
  analyticsSnapshots  AnalyticsSnapshot[]

  @@index([creatorId])
  @@index([categoryId])
  @@index([status])
  @@index([searchVector])
  @@map("assets")
}

model AssetFile {
  id         String @id @default(uuid()) @db.Uuid
  assetId    String @db.Uuid
  storageKey String
  filename   String
  mimeType   String
  sizeBytes  Int
  version    Int    @default(1)

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("asset_files")
}

model AssetMedia {
  id         String    @id @default(uuid()) @db.Uuid
  assetId    String    @db.Uuid
  storageKey String
  kind       MediaKind
  position   Int       @default(0)

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("asset_media")
}

model Category {
  id       String  @id @default(uuid()) @db.Uuid
  name     String  @unique
  slug     String  @unique
  parentId String? @db.Uuid

  parent   Category?  @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryParent")
  assets   Asset[]

  @@index([slug])
  @@map("categories")
}

model Tag {
  id     String     @id @default(uuid()) @db.Uuid
  name   String     @unique

  assets AssetTag[]

  @@index([name])
  @@map("tags")
}

model AssetTag {
  id      String @id @default(uuid()) @db.Uuid
  assetId String @db.Uuid
  tagId   String @db.Uuid

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([assetId, tagId])
  @@index([assetId])
  @@index([tagId])
  @@map("asset_tags")
}

model License {
  id      String      @id @default(uuid()) @db.Uuid
  code    LicenseCode @unique
  name    String
  summary String

  assets Asset[]

  @@map("licenses")
}

model Order {
  id                    String      @id @default(uuid()) @db.Uuid
  buyerId               String      @db.Uuid
  status                OrderStatus
  subtotalCents         Int
  platformFeeCents      Int
  totalCents            Int
  taxCents              Int         @default(0)
  currency              String
  stripePaymentIntentId String?
  // Billing address snapshot — captured at order time so tax is
  // reproducible even if the buyer later changes their address.
  billingCountry  String?
  billingRegion   String?
  billingPostal   String?

  createdAt DateTime @default(now())

  buyer   User          @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  items   OrderItem[]
  taxes   TaxLineItem[]

  @@index([buyerId, createdAt])
  @@map("orders")
}

model OrderItem {
  id          String      @id @default(uuid()) @db.Uuid
  orderId     String      @db.Uuid
  assetId     String      @db.Uuid
  priceCents  Int
  creatorId   String      @db.Uuid
  licenseCode LicenseCode

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Restrict)
  user  User  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  downloadGrants DownloadGrant[]

  @@index([creatorId])
  @@map("order_items")
}

model DownloadGrant {
  id            String   @id @default(uuid()) @db.Uuid
  orderItemId   String   @db.Uuid
  buyerId       String   @db.Uuid
  expiresAt     DateTime
  downloadCount Int      @default(0)
  maxDownloads  Int

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  buyer     User      @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  downloads AssetDownload[]

  @@index([buyerId, expiresAt])
  @@map("download_grants")
}

model Review {
  id        String   @id @default(uuid()) @db.Uuid
  assetId   String   @db.Uuid
  userId    String   @db.Uuid
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([assetId, userId])
  @@index([assetId])
  @@map("reviews")
}

model Payout {
  id               String       @id @default(uuid()) @db.Uuid
  creatorId        String       @db.Uuid
  amountCents      Int
  currency         String
  status           PayoutStatus
  stripeTransferId String?

  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@map("payouts")
}

model DiscountCode {
  id             String    @id @default(uuid()) @db.Uuid
  creatorId      String    @db.Uuid
  code           String
  percentOff     Int
  maxRedemptions Int?
  expiresAt      DateTime?

  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([creatorId, code])
  @@index([creatorId])
  @@map("discount_codes")
}

model Collection {
  id         String  @id @default(uuid()) @db.Uuid
  title      String
  slug       String  @unique
  isFeatured Boolean @default(false)
  curatorId  String  @db.Uuid

  curator User              @relation(fields: [curatorId], references: [id], onDelete: Cascade)
  assets  CollectionAsset[]

  @@map("collections")
}

model CollectionAsset {
  id           String @id @default(uuid()) @db.Uuid
  collectionId String @db.Uuid
  assetId      String @db.Uuid
  position     Int    @default(0)

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  asset      Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([collectionId, assetId])
  @@index([collectionId])
  @@map("collection_assets")
}

// ──────────────────────────────────────────────────────────────────────
// Creator analytics + AI generation tables
// ──────────────────────────────────────────────────────────────────────

enum AITaskKind {
  listing_copywriter
  asset_critique
  sales_coach
  metadata_seo
}

enum AIJobStatus {
  pending
  running
  completed
  failed
}

// One row per asset-page load. Used for conversion-funnel analytics
// (views → adds-to-cart → purchases). Aggregated nightly for retention.
model AssetView {
  id        String   @id @default(uuid()) @db.Uuid
  assetId   String   @db.Uuid
  viewerId  String?  @db.Uuid  // null = anonymous (rare on Elixio, but log it)
  referrer  String?
  createdAt DateTime @default(now())

  asset  Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  viewer User? @relation(fields: [viewerId], references: [id], onDelete: SetNull)

  @@index([assetId, createdAt])
  @@index([viewerId, createdAt])
  @@index([createdAt])
  @@map("asset_views")
}

// One row per file download grant used. Drives per-asset download
// counts and creator "your top assets by downloads" leaderboard.
model AssetDownload {
  id        String   @id @default(uuid()) @db.Uuid
  assetId   String   @db.Uuid
  buyerId   String   @db.Uuid
  grantId   String?  @db.Uuid  // optional link to DownloadGrant
  createdAt DateTime @default(now())

  asset  Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  buyer  User  @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  grant  DownloadGrant? @relation(fields: [grantId], references: [id], onDelete: SetNull)

  @@index([assetId, createdAt])
  @@index([buyerId, createdAt])
  @@map("asset_downloads")
}

// Job record for every Gemini call so we can:
// - audit what was generated
// - throttle per-creator rate limits
// - show "your AI history" in the studio
// - replay/regenerate on user request
model AIGeneration {
  id          String      @id @default(uuid()) @db.Uuid
  creatorId   String      @db.Uuid
  kind        AITaskKind
  status      AIJobStatus @default(pending)
  inputJson   Json        // the prompt inputs (filename, free-text description, etc.)
  outputJson  Json?       // structured response from Gemini
  errorMessage String?
  tokensIn    Int?
  tokensOut   Int?
  costUsd     Float?
  durationMs  Int?
  createdAt   DateTime    @default(now())
  completedAt DateTime?

  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId, createdAt])
  @@index([creatorId, kind])
  @@index([status])
  @@map("ai_generations")
}

// Per-asset asset-level snapshot of daily metrics. Populated by the
// analytics aggregation cron (and on-demand for the creator dashboard).
// Keeping a snapshot table makes the dashboard queries O(dayCount)
// instead of O(eventsCount).
model AnalyticsSnapshot {
  id            String   @id @default(uuid()) @db.Uuid
  creatorId     String   @db.Uuid
  assetId       String?  @db.Uuid  // null = creator-wide rollup row
  date          DateTime @db.Date

  views         Int @default(0)
  uniqueViewers Int @default(0)
  downloads     Int @default(0)
  purchases     Int @default(0)
  revenueCents  Int @default(0)

  creator User  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  asset   Asset? @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([creatorId, assetId, date])
  @@index([creatorId, date])
  @@index([assetId, date])
  @@map("analytics_snapshots")
}

// Log of every bulk operation (price-update batch, archive-batch, etc.)
// so creators can audit what happened + undo if needed.
model BulkOperation {
  id          String   @id @default(uuid()) @db.Uuid
  creatorId   String   @db.Uuid
  kind        String   // "price_update" | "tag_add" | "tag_remove" | "publish" | "archive" | "delete"
  affectedIds String[] // asset ids affected
  beforeJson  Json?    // snapshot of pre-change values for undo
  afterJson   Json?    // snapshot of post-change values
  rolledBackAt DateTime?
  createdAt   DateTime @default(now())

  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId, createdAt])
  @@map("bulk_operations")
}

// Internal rate-limit table managed by lib/rate-limit.ts.
// Modeled here so Prisma migrations don't drop it.
model RateLimitBucket {
  key         String   @id
  windowStart DateTime @default(now()) @map("window_start")
  count       Int      @default(0)

  @@map("rate_limit_buckets")
}

// ──────────────────────────────────────────────────────────────────────
// Tax regions + line items
// ──────────────────────────────────────────────────────────────────────

enum TaxKind {
  vat       // EU + UK value-added tax
  gst       // Goods & Services Tax (AU, NZ, SG, CA, IN)
  hst       // Harmonized Sales Tax (CA combined federal+provincial)
  pst       // Provincial Sales Tax (CA separate)
  qst       // Quebec Sales Tax
  igst      // Indian inter-state GST
  cgst      // Indian central GST
  sgst      // Indian state GST
  sales     // US state sales tax
  iva       // Spanish/Italian value-added
  pis_cofins // Brazil federal
  icms      // Brazil state
  iss       // Brazil municipal
  consumption // Japan consumption tax
  none      // no tax region (display only)
}

model TaxRegion {
  id          String   @id @default(uuid()) @db.Uuid
  // ISO 3166-1 alpha-2 country code ("US", "DE", "IN", …)
  country     String
  // ISO 3166-2 subdivision code for state/province ("US-CA", "DE-BY", …)
  // Empty string = country-level rate (e.g. federal GST)
  region      String   @default("")
  // Human label, e.g. "California", "Bayern", "Maharashtra"
  label       String
  // Which kind of tax this row represents
  kind        TaxKind
  // Rate as a fraction (0.0725 = 7.25%). Stored as Decimal for precision.
  rate        Decimal  @db.Decimal(8, 6)
  // Currency this rate applies in (for display)
  currency    String
  // Optional: reduced rates for specific categories (e.g. food 5%, books 0%)
  // Future-proofing — for now we store the standard rate only.
  description String?
  // When this rate was last verified by a human
  lastVerified DateTime?
  // Source URL (e.g. state.gov, ec.europa.eu) so future verifications
  // can confirm the rate is still current
  sourceUrl   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([country, region, kind])
  @@index([country, region])
  @@index([isActive])
  @@map("tax_regions")
}

// Tax line items on each Order. An order can have multiple tax lines
// (federal GST + state sales, VAT + reduced VAT, etc.) — these are
// snapshotted at order-creation time so historical orders stay
// correct even when rates change.
model TaxLineItem {
  id          String   @id @default(uuid()) @db.Uuid
  orderId     String   @db.Uuid
  kind        TaxKind
  label       String       // "California State Sales Tax" — snapshot at calc time
  region      String?      // "US-CA"
  rate        Decimal  @db.Decimal(8, 6)
  // Amount in the order's currency, in cents
  amountCents Int
  // Snapshot of the input that produced this line (for audit)
  baseCents   Int
  createdAt   DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("tax_line_items")
}
