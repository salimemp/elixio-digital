// Required
DATABASE_URL=postgresql://user:password@localhost:5432/elixio
JWT_SECRET=change-me-to-a-random-string-with-at-least-32-characters

// Required for production — base64-encoded 32-byte key for encrypting
// sensitive user data at rest (TOTP seeds, OAuth tokens). Generate with:
//   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ELIXIO_MFA_KEY_ENCRYPTION_KEY=change-me-base64-encoded-32-bytes

// Required for transactional email. Sign up at https://resend.com
RESEND_API_KEY=re_...
EMAIL_FROM="Elixio Digital <no-reply@elixiodigital.com>"

// Required for production URLs (used in email links + OAuth callbacks)
ELIXIO_API_URL=http://localhost:3000
ELIXIO_WEB_URL=http://localhost:3001
ELIXIO_MOBILE_URL=elixio://

// Optional: Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

// Optional: GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

// Server
PORT=3000
CORS_ORIGIN=http://localhost:3001
NODE_ENV=development

// WebAuthn (passkeys) — your server's "relying party" identifier.
// Must be the registrable domain (no protocol, no port).
ELIXIO_WEBAUTHN_RP_ID=localhost
// Origin list (comma-separated). Includes "localhost:3001" for dev.
ELIXIO_WEBAUTHN_ORIGINS=http://localhost:3001
